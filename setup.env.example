# Claude Code Project Template - Setup Configuration
# Copy this file to setup.env and fill in your values.
# Then run: bash setup.sh --config setup.env
#
# Any variable left empty or omitted will use its default value.

# ─── Core ───────────────────────────────────────────
PROJECT_NAME="My Project"
# PROJECT_SLUG is auto-generated from PROJECT_NAME if omitted

# ─── GitHub ─────────────────────────────────────────
GITHUB_OWNER="your-username"
GITHUB_REPO=""  # defaults to PROJECT_SLUG

# ─── GitHub Project Board ──────────────────────────
# If you have an existing board, set the project number to auto-detect all IDs.
# If empty, setup will CREATE a new board with all required fields automatically.
# Set CREATE_PROJECT="n" to skip board creation entirely.
GITHUB_PROJECT_NUMBER=""
# CREATE_PROJECT="y"  # defaults to "y" in non-interactive mode

# Sprint IDs (auto-detected from project board if left empty)
# SPRINT_1=""
# SPRINT_2=""
# SPRINT_3=""

# ─── Documentation Target ────────────────────────────
# Where should project documentation be generated?
# Options: "notion" (Notion database), "local" (local markdown), "both"
DOC_TARGET="local"

# ─── Notion ─────────────────────────────────────────
# Only relevant when DOC_TARGET includes "notion" (i.e. "notion" or "both")
# Set to "y" to enable Notion documentation integration
USE_NOTION="n"
# If you have an existing Notion database, set its data source ID.
# Leave as NOT_CONFIGURED to use /setup-notion after setup.
# NOTION_DATABASE_ID="NOT_CONFIGURED"

# ─── Agent Teams (Build Pipeline) ─────────────────────
# Enable parallel implementation in Phase 4 (backend + frontend + integration agents)
USE_AGENT_TEAMS="y"

# ─── Tech Stack ─────────────────────────────────────
TEST_COMMAND_BACKEND="REPLACE_ME"
TEST_COMMAND_FRONTEND="REPLACE_ME"
E2E_TEST_COMMAND="npx playwright test"
DEV_SERVER_BACKEND="REPLACE_ME"
DEV_SERVER_FRONTEND="REPLACE_ME"
# Keep default ports (y) or customize below (n). Defaults to "y".
# KEEP_DEFAULT_PORTS="y"
DEV_PORT_BACKEND="8000"
DEV_PORT_FRONTEND="5173"
# LOCAL_URL defaults to http://localhost:$DEV_PORT_FRONTEND
PROD_URL="REPLACE_ME"
FRONTEND_DIR="frontend"

# ─── Deployment ─────────────────────────────────────
DEPLOY_COMMAND="REPLACE_ME"
HEALTH_CHECK_COMMAND="REPLACE_ME"
DOCKER_CHECK_COMMAND="none"

# ─── Data Protection ───────────────────────────────
PROTECTED_DATA_DIR="data/"
# PROTECTED_DATA_PATTERNS defaults to PROTECTED_DATA_DIR

# ─── Git ────────────────────────────────────────────
# Auto-init git repo (y/n). Defaults to "y" in non-interactive mode.
# INIT_GIT="y"
